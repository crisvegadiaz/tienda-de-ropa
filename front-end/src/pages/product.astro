---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import SelectOption from "../components/SelectOption.astro";

const id: string | null = Astro.url.searchParams.get("id");

interface Producto {
  nombre: string;
  precio: string;
  genero: string;
}

interface Variante {
  id: string;
  color: string;
  talle: string;
  cantidad: number;
}

interface ProductoYVariantes {
  producto: Producto | null;
  variantes: Variante[] | null;
}

if (!id) {
  return Astro.redirect("/error");
}

async function fetchProductoYVariantes(
  id: string,
): Promise<ProductoYVariantes> {
  try {
    const [resProducto, resVariantes] = await Promise.all([
      fetch(`http://localhost:3000/producto/${id}`),
      fetch(`http://localhost:3000/producto/${id}/variantes`),
    ]);

    if (!resProducto.ok) {
      throw new Error(resProducto.statusText);
    }
    if (!resVariantes.ok) {
      throw new Error(resVariantes.statusText);
    }

    const producto = await resProducto.json();
    const variantes = await resVariantes.json();
    return { producto, variantes };
  } catch (error) {
    console.error("Error fetching product data:", error);
    return { producto: null, variantes: null };
  }
}

const { producto, variantes } = await fetchProductoYVariantes(id);

if (!producto) {
  return Astro.redirect("/error");
}

const colores = Array.from(new Set(variantes?.map((v) => v.color) || []));
const talles =
  variantes?.filter((v) => v.color === colores[0]).map((v) => v.talle) || [];
---

<Layout>
  <main
    id="product-container"
    data-variantes={JSON.stringify(variantes)}
    data-nombre={producto.nombre}
    data-precio={producto.precio}
  >
    <a href="/shoppingcart">carrito</a>
    <img
      src={`http://localhost:3000/producto/img/${id}`}
      alt={producto.nombre}
      width="400"
    />
    <h1>{producto.nombre}</h1>
    <p>Precio: ${producto.precio}</p>
    <p>Género: {producto.genero}</p>

    <h2>variantes disponibles</h2>

    <form id="add-to-cart-form">
      <SelectOption list={colores} name="color" />
      <SelectOption list={talles} name="talle" />
      <input
        type="number"
        min="1"
        value="1"
        class="input-cantidad"
        name="cantidad"
      />
      <button type="submit" class="btn-add-to-cart">Agregar al carrito</button>
    </form>
  </main>

  <script>
    import { agregarProducto } from "../stores/store";
    const container = document.getElementById("product-container");
    const formElement = document.getElementById(
      "add-to-cart-form",
    ) as HTMLFormElement;
    const colorSelect = document.querySelector(
      'select[name="color"]',
    ) as HTMLSelectElement;
    const talleSelect = document.querySelector(
      'select[name="talle"]',
    ) as HTMLSelectElement;

    interface Variante {
      id: string;
      color: string;
      talle: string;
      cantidad: number;
    }
    const variantes = JSON.parse(
      container?.dataset.variantes || "[]",
    ) as Variante[];
    const nombreProducto = container?.dataset.nombre || "";
    const precioProducto = Number(container?.dataset.precio) || 0;

    colorSelect.addEventListener("change", () => {
      const colorSeleccionado = colorSelect.value;
      const tallesDisponibles = variantes
        .filter((v) => v.color === colorSeleccionado)
        .map((v) => v.talle);
      talleSelect.innerHTML = "";
      tallesDisponibles.forEach((talle) => {
        const option = document.createElement("option");
        option.value = talle;
        option.textContent = talle;
        talleSelect.appendChild(option);
      });
    });

    formElement?.addEventListener("submit", function (e) {
      e.preventDefault();
      const formData = new FormData(formElement);
      const color = formData.get("color");
      const talle = formData.get("talle");
      const cantidad = formData.get("cantidad");

      const idVariante = variantes.filter(
        (v) => v.color === color && v.talle === talle,
      )[0]?.id;

      if (!idVariante) {
        alert("Por favor seleccione una variante válida");
        return;
      }

      agregarProducto({
        idVariante,
        nombre: nombreProducto,
        precio: precioProducto,
        cantidad: Number(cantidad),
        color: String(color),
        talle: String(talle),
      });
    });
  </script>
</Layout>

<style>
  main {
    width: 50%;
    margin: 2rem auto;
    background: #fff;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }
  a{
    display: inline-block;
    margin-bottom: 1rem;
    color: #4caf50;
    text-decoration: none;
    font-weight: bold;
    font-size: 1.5rem;
  }
  img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 1rem;
  }
  h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  p {
    margin-bottom: 0.5rem;
  }
  input[type="number"] {
    width: 80px;
    padding: 0.5rem;
    margin-right: 1rem;
    border: 1px solid #ccc;
    border-radius: 4px;
  }
  .btn-add-to-cart {
    margin-top: 1rem;
    padding: 0.75rem 1.5rem;
    background: #4caf50;
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition:
      background 0.3s,
      transform 0.2s;
  }
</style>
