---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main>
    <h1>Carrito de Compras</h1>
    <ul></ul>
    <div class="checkout-section">
      <button class="checkout-btn">Finalizar Compra</button>
      <h3 class="total">Total: $0</h3>
    </div>
  </main>

  <script>
    import { $carrito, eliminarProducto, type Producto } from "../stores/store";

    const ulElement = document.querySelector("ul");
    const h3Element = document.querySelector(".total");
    const btnBuy = document.querySelector(".checkout-btn");
    const formatter = new Intl.NumberFormat("es-AR", {
      style: "currency",
      currency: "ARS",
    });

    // Función para renderizar el carrito
    function renderizarCarrito(productos: readonly Producto[]) {
      if (!ulElement || !h3Element) return;
      ulElement.innerHTML = "";
      let nuevoTotal = 0;

      productos.forEach((item) => {
        const subtotal = item.precio * item.cantidad;
        nuevoTotal += subtotal;

        const li = document.createElement("li");
        li.innerHTML = `
          <div class="item-info">
            <h4>${item.nombre}</h4>
            <p>Talle: <span>${item.talle || "N/A"}</span> | Color: <span>${item.color || "N/A"}</span></p>
          </div>
          <div class="item-meta">
            <span class="item-price">${formatter.format(item.precio)}</span>
            <span class="item-qty">x${item.cantidad}</span>
          </div>
          <button class="remove-btn" data-id="${item.idVariante}">Eliminar</button>
        `;
        ulElement.appendChild(li);
      });

      h3Element.textContent = `Total: ${formatter.format(nuevoTotal)}`;
    }

    // Suscribirse al store para que la UI reaccione a cambios automáticamente
    $carrito.subscribe((nuevoEstado) => {
      renderizarCarrito(nuevoEstado);
    });

    // Delegación de eventos para eliminar productos
    ulElement?.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains("remove-btn")) {
        const id = target.getAttribute("data-id");
        if (id) eliminarProducto(id);
      }
    });

    btnBuy?.addEventListener("click", (e) => {
      console.log($carrito.get())
    });
  </script>
</Layout>

<style is:global>
  main {
    width: 50%;
    margin: 2rem auto;
    background: #fff;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  ul {
    list-style-type: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  li {
    border: 1px solid #ddd;
    padding: 1rem;
    border-radius: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #f9f9f9;
  }
  .item-info {
    font-size: 1rem;
  }

  .item-meta {
    font-size: 1rem;
  }
  .checkout-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    margin: 0 0.5rem;
  }
</style>
